From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: build-bot <build@example.com>
Date: Mon, 2 Mar 2026 00:00:00 +0000
Subject: [PATCH] packages: compile debug libmpv

---
 cmake/packages_check.cmake |  2 ++
 packages/mpv.cmake         | 23 +++++++++++++++++++++--
 2 files changed, 23 insertions(+), 2 deletions(-)

diff --git a/cmake/packages_check.cmake b/cmake/packages_check.cmake
index acf8ccb..1234567 100644
--- a/cmake/packages_check.cmake
+++ b/cmake/packages_check.cmake
@@ -7,6 +7,7 @@ if(COMPILER_TOOLCHAIN STREQUAL "gcc")
     set(ffmpeg_extra_libs "-lstdc++")
     set(libjxl_unaligned_vector "-Wa,-muse-unaligned-vector-move") # fix crash on AVX2 proc (64bit) due to unaligned stack memory
     set(mpv_copy_debug COMMAND ${CMAKE_COMMAND} -E copy <BINARY_DIR>/mpv.debug ${CMAKE_CURRENT_BINARY_DIR}/mpv-debug/mpv.debug)
+    set(mpv_strip_release_only COMMAND ${EXEC} ${TARGET_ARCH}-strip -s <BINARY_DIR>/libmpv-2.dll)
     set(mpv_add_debuglink COMMAND ${EXEC} ${TARGET_ARCH}-objcopy --only-keep-debug <BINARY_DIR>/mpv.exe <BINARY_DIR>/mpv.debug
                           COMMAND ${EXEC} ${TARGET_ARCH}-strip -s <BINARY_DIR>/mpv.exe
                           COMMAND ${EXEC} ${TARGET_ARCH}-objcopy --add-gnu-debuglink=<BINARY_DIR>/mpv.debug <BINARY_DIR>/mpv.exe
@@ -17,6 +18,7 @@ elseif(COMPILER_TOOLCHAIN STREQUAL "clang")
     set(vapoursynth_pkgconfig_libs "-lVapourSynth -Wl,-delayload=VapourSynth.dll")
     set(ffmpeg_extra_libs "-lc++")
     set(mpv_copy_debug COMMAND ${CMAKE_COMMAND} -E copy <BINARY_DIR>/mpv.pdb ${CMAKE_CURRENT_BINARY_DIR}/mpv-debug/mpv.pdb)
+    set(mpv_strip_release_only COMMAND ${EXEC} llvm-strip -s <BINARY_DIR>/libmpv-2.dll)
     set(mpv_lto_mode -Db_lto_mode=thin)
     if(CLANG_PACKAGES_LTO)
         set(ffmpeg_lto --enable-lto=thin)
diff --git a/packages/mpv.cmake b/packages/mpv.cmake
index 8624aec..abcdefg 100644
--- a/packages/mpv.cmake
+++ b/packages/mpv.cmake
@@ -60,10 +60,23 @@ ExternalProject_Add(mpv
     LOG_DOWNLOAD 1 LOG_UPDATE 1 LOG_CONFIGURE 1 LOG_BUILD 1 LOG_INSTALL 1
 )
 
+ExternalProject_Add_Step(mpv copy-debug-dll
+    DEPENDEES build
+    DEPENDERS strip-binary
+    COMMAND ${CMAKE_COMMAND} -E copy <BINARY_DIR>/libmpv-2.dll ${CMAKE_CURRENT_BINARY_DIR}/mpv-dev-debug/libmpv-2.dll
+    COMMAND ${CMAKE_COMMAND} -E copy <BINARY_DIR>/libmpv.dll.a ${CMAKE_CURRENT_BINARY_DIR}/mpv-dev-debug/libmpv.dll.a
+    COMMAND ${CMAKE_COMMAND} -E copy <SOURCE_DIR>/include/mpv/client.h       ${CMAKE_CURRENT_BINARY_DIR}/mpv-dev-debug/include/mpv/client.h
+    COMMAND ${CMAKE_COMMAND} -E copy <SOURCE_DIR>/include/mpv/stream_cb.h    ${CMAKE_CURRENT_BINARY_DIR}/mpv-dev-debug/include/mpv/stream_cb.h
+    COMMAND ${CMAKE_COMMAND} -E copy <SOURCE_DIR>/include/mpv/render.h       ${CMAKE_CURRENT_BINARY_DIR}/mpv-dev-debug/include/mpv/render.h
+    COMMAND ${CMAKE_COMMAND} -E copy <SOURCE_DIR>/include/mpv/render_gl.h    ${CMAKE_CURRENT_BINARY_DIR}/mpv-dev-debug/include/mpv/render_gl.h
+    COMMENT "Copying debug libmpv with symbols"
+)
+
 ExternalProject_Add_Step(mpv strip-binary
-    DEPENDEES build
+    DEPENDEES copy-debug-dll
     ${mpv_add_debuglink}
+    ${mpv_strip_release_only}
     COMMENT "Stripping mpv binaries"
 )
 
 ExternalProject_Add_Step(mpv copy-binary
@@ -99,6 +112,9 @@ ExternalProject_Add_Step(mpv copy-package-dir
     COMMAND mv ${CMAKE_CURRENT_BINARY_DIR}/mpv-debug ${CMAKE_BINARY_DIR}/mpv-debug-${TARGET_CPU}${x86_64_LEVEL}-${BUILDDATE}
     COMMAND ${RENAME} <SOURCE_DIR> ${CMAKE_BINARY_DIR}/mpv-debug-${TARGET_CPU}${x86_64_LEVEL}-${BUILDDATE}
 
+    COMMAND mv ${CMAKE_CURRENT_BINARY_DIR}/mpv-dev-debug ${CMAKE_BINARY_DIR}/mpv-dev-debug-${TARGET_CPU}${x86_64_LEVEL}-${BUILDDATE}
+    COMMAND ${RENAME} <SOURCE_DIR> ${CMAKE_BINARY_DIR}/mpv-dev-debug-${TARGET_CPU}${x86_64_LEVEL}-${BUILDDATE}
+
     COMMAND mv ${CMAKE_CURRENT_BINARY_DIR}/mpv-dev ${CMAKE_BINARY_DIR}/mpv-dev-${TARGET_CPU}${x86_64_LEVEL}-${BUILDDATE}
     COMMAND ${RENAME} <SOURCE_DIR> ${CMAKE_BINARY_DIR}/mpv-dev-${TARGET_CPU}${x86_64_LEVEL}-${BUILDDATE}
     COMMENT "Moving mpv package folder"
-- 
2.51.2.windows.1
